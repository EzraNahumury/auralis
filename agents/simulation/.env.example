# Ollama config — mirrors frontend/.env.local.example
#
# (A) Ollama Cloud (managed, requires API key)
#     OLLAMA_HOST=https://ollama.com
#     OLLAMA_KEY=<your_api_key>
#     OLLAMA_MODEL=gpt-oss:120b-cloud
#
# (B) Local Ollama daemon (free, no key)
#     OLLAMA_HOST=http://localhost:11434
#     OLLAMA_MODEL=llama3.2
#
# Make sure the model is pulled:  ollama pull llama3.2

OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_KEY=

# Output folder for simulation reports
OUTPUT_DIR=./outputs
