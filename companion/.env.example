# Portaldot WebSocket endpoint.
# Try these in order if one is unresponsive:
#   1. Railway public dev node (community-hosted):
#      wss://drip-node-production.up.railway.app
#   2. Railway with /node path (older URL):
#      wss://drip-backend-production-8d86.up.railway.app/node
#   3. Your own local portaldot_dev:
#      ws://127.0.0.1:9944
PORTALDOT_WS=wss://drip-node-production.up.railway.app

# SS58 prefix used to format addresses.
# Portaldot uses 42 (same as generic Substrate).
PORTALDOT_SS58=42

# Token symbol (purely for display in logs).
PORTALDOT_TOKEN_SYMBOL=POT

# Decimal places. Portaldot uses 14 on mainnet but the dev binary may
# expose 12. The script reads this from the chain at startup, this is
# only used for human-readable amount printing if chain lookup fails.
PORTALDOT_TOKEN_DECIMALS=12

# Amount each member deposits to the group, in whole token units.
# 100 POT × 3 members = 300 POT total pot.
DEPOSIT_AMOUNT_POT=100

# How many of the 3 group members must sign to release the pot.
# 2-of-3 mirrors the Auralis weighted-vote majority semantic.
MULTISIG_THRESHOLD=2

# Output: where to save the JSON proof bundle of all transactions.
TX_PROOF_OUTPUT=./tx-proof.json
