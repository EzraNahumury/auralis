# Ollama config — used by /api/ai/requester and /api/ai/reviewer.
# The Next.js routes call your locally-running Ollama daemon to score
# each withdrawal request (Requester Agent) and to gather per-member
# votes (Reviewer Agents). If OLLAMA_HOST is unreachable, the UI falls
# back to the seeded mock verdict shipped with the demo.

OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Tip: smaller and faster choices that still give usable JSON:
#   - llama3.2:3b     ← good default
#   - qwen2.5:7b      ← stronger reasoning
#   - phi3:mini       ← very fast, tighter JSON
# Make sure you've pulled it first:
#   ollama pull llama3.2
