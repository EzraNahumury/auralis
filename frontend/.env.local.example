# Ollama config — used by /api/ai/requester and /api/ai/reviewer.
#
# Two ways to run the AI layer:
#
# (A) Ollama Cloud (managed, requires API key)
#     OLLAMA_HOST=https://ollama.com
#     OLLAMA_KEY=<your_api_key>
#     OLLAMA_MODEL=gpt-oss:120b-cloud
#
# (B) Local Ollama daemon (free, no key)
#     OLLAMA_HOST=http://localhost:11434
#     OLLAMA_MODEL=llama3.2
#     # OLLAMA_KEY is not required for local
#
# If OLLAMA_HOST is unreachable, the UI falls back to the seeded mock
# verdict so the demo keeps working.

OLLAMA_HOST=https://ollama.com
OLLAMA_KEY=
OLLAMA_MODEL=gpt-oss:120b-cloud

# Tip — other models that produce reliable JSON:
#   Cloud:  gpt-oss:120b-cloud  ← strongest reasoning
#   Local:  llama3.2  qwen2.5:7b  phi3:mini
#
# For local, make sure you've pulled it:
#   ollama pull llama3.2
